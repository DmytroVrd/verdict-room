# Band Cloud defaults. Override only for self-hosted Band.
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Primary providers (both prepaid via hackathon promos): AI/ML API + Featherless.
AIML_API_KEY=
FEATHERLESS_API_KEY=

# Optional backup providers. Leave empty to skip; the fallback chain ignores
# providers without a key.
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Tool-calling roles (Arbiter drives the state machine; Researcher and Scout
# call web tools) run on AI/ML API. Debate-only roles run on Featherless.
# DeepSeek IDs verified in the Featherless catalog on 2026-06-12; swap to
# Kimi-K2 / GLM 4.6 if they appear in your plan's catalog UI.
ARBITER_MODEL=aiml:openai/gpt-4.1-mini
RESEARCHER_MODEL=aiml:openai/gpt-4.1-mini
SCOUT_MODEL=aiml:openai/gpt-4.1-mini
ADVOCATE_MODEL=featherless:deepseek-ai/DeepSeek-V3.2
CRITIC_MODEL=featherless:deepseek-ai/DeepSeek-V3.1-Terminus
COMPLIANCE_MODEL=featherless:deepseek-ai/DeepSeek-V3.2

# Comma-separated fallback models used when their provider key exists.
LLM_FALLBACK_MODELS=aiml:openai/gpt-4.1-mini,featherless:deepseek-ai/DeepSeek-V3.2,groq:openai/gpt-oss-120b
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=45
DEBATE_TURN_TIMEOUT=120
START_COMPLIANCE=true

