# Band Cloud defaults. Override only for self-hosted Band.
BAND_REST_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Free-tier provider keys. Configure at least one.
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
AIML_API_KEY=

# Current defaults as of 2026-06-12. All are configurable because catalogs rotate.
ARBITER_MODEL=groq:openai/gpt-oss-120b
RESEARCHER_MODEL=groq:openai/gpt-oss-120b
SCOUT_MODEL=openrouter:openrouter/free
ADVOCATE_MODEL=gemini:gemini-3.5-flash
CRITIC_MODEL=aiml:openai/gpt-4.1-mini
COMPLIANCE_MODEL=gemini:gemini-3.5-flash

# Comma-separated fallback models used when their provider key exists.
LLM_FALLBACK_MODELS=groq:openai/gpt-oss-120b,gemini:gemini-3.5-flash,openrouter:openrouter/free
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=45
DEBATE_TURN_TIMEOUT=120
START_COMPLIANCE=true

